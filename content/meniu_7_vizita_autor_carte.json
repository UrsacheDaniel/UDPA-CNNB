  "contentHtml": "<div class=\"insidem\">\n                  <!-- component -->\n      <div id=\"phocagallery\" class=\"pg-category-view\">\n<div class=\"pg-category-view-desc\"><blockquote>\n<p style=\"margin-bottom: 12pt; line-height: 200%;\"><span style=\"font-family: Tahoma, 'sans-serif'; color: blue; background: white; font-size: 12pt;\">Mai 2022</span></p>\n<p style=\"margin-bottom: 12pt; line-height: 200%;\"><span style=\"font-family: Tahoma, 'sans-serif'; color: blue; background: white; font-size: 12pt;\">Elevii clasei a VI-a ai Colegiului Nicolae Bălcescu, coordonați de dna prof. Mirela Curcă, alături de dna director adj. Carmen Botea, s-au bucurat de prezența domnului Liviu Chifane, autorul seriei de cărți pentru copii „Eroi la întâmplare”, „Copiii deltei” și „Sparg nuci”. Copiii au primit autografe și răspunsuri întrebarilor lor istețe despre aventurile și personajele create de autor.</span></p>\n</blockquote></div>\n<div id=\"pg-icons\"></div><div style=\"clear:both\"></div>\n\n<div class=\"phocagallery-box-file pg-box-image\" style=\"height:238px; width:220px;\">\n<div class=\"phocagallery-box-file-first\" style=\"height:218px;width:218px;margin:auto;\">\n<div class=\"phocagallery-box-file-second\">\n<div class=\"phocagallery-box-file-third\">\n<a class=\"jaklightbox\" title=\"\" href=\"#/images/phocagallery/vizita_autor_carte_2022/thumbs/phoca_thumb_l_img-20220412-wa0005.jpg\" onclick=\"gjaks.show(0); return false;\"><img src=\"http://www.cnnb.ro/images/phocagallery/vizita_autor_carte_2022/thumbs/phoca_thumb_m_img-20220412-wa0005.jpg\" alt=\"Vizită autor carte\" class=\"pg-image responsive-img\"></a>\n</div></div></div>\n<div class=\"pg-name\" style=\"font-size:12px\">Vizită autor carte</div></div>\n\n<div class=\"phocagallery-box-file pg-box-image\" style=\"height:238px; width:220px;\">\n<div class=\"phocagallery-box-file-first\" style=\"height:218px;width:218px;margin:auto;\">\n<div class=\"phocagallery-box-file-second\">\n<div class=\"phocagallery-b