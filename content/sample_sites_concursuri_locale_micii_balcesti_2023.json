  "contentHtml": "<div class=\"insidem\">\n                  <!-- component -->\n      \n<div class=\"news_item_a\">\n\t\t\n\t\t\n\t\n\t\t<div id=\"bt-zt\"><a href=\"http://i-realtor.org/\" target=\"_blank\" title=\"обзоры недвижимости\">обзоры недвижимости</a><br><a href=\"http://joomla-master.org/joomla-3.0.html/\" target=\"_blank\" title=\"лучшие шаблоны Joomla 3.0\">лучшие шаблоны Joomla 3.0</a></div>\t\t\n\t\n\t\n\t\n\t<div class=\"newsitem_text\">\n\t\t              \n\t\t        \n        \n\t\t<p align=\"center\" style=\"text-align: center; line-height: 250%;\"><span style=\"text-decoration: underline;\"><a href=\"#/alte/2023/micii_balcesti/subiectele_la_micii_balcesti_mai_2023.pdf\"><b style=\"color: #0000ff;\"><span style=\"font-size: 14pt; line-height: 46.6667px;\">SUBIECTELE LA CONCURUL DIN 27 MAI 2023</span></b></a></span>&nbsp;</p>\n<p align=\"center\" style=\"text-align: center; line-height: 250%;\">&nbsp;</p>\n<ul>\n<li><span style=\"color: #0000ff;\"><b><span style=\"font-size: 14pt; line-height: 250%;\">Înscrierea la Concursul „Micii Bălceşti” se face pe baza unei cereri-tip care se găseşte la secretariatul Colegiului Naţional „Nicolae Bălcescu” în perioada: 22.05-26.05.2023;</span></b></span></li>\n<li><span style=\"color: #0000ff;\"><b><span style=\"font-size: 14pt; line-height: 250%;\">Concursul „Micii Bălceşti” are loc în data de 27.05.2023 începând cu ora 10,00;</span></b></span></li>\n<li><span style=\"color: #0000ff;\"><b><span style=\"font-size: 14pt; line-height: 250%;\">Accesul candidaţilor se va face în data de 27.05.2023 în intervalul orar 9,00-9,30;</span></b></span></li>\n<li><span style=\"color: #0000ff;\"><b><span style=\"font-size: 14pt; line-height: 250%;\">Elevii participanţi vor rezolva subiecte, care vor conține elemente de Limba și literatura română şi de matematică;</span></b></span></li>\n<li><span style=\"color: #0000ff;\"><b><span style=\"font-size: 14pt; line-height: 250%;\">Timp de lucru 90 de minute fără pauză.</span></b></span></li>\n</ul>\n<p>&nbsp;</p>\n<p><img src=\"http://www.cnnb.ro/alte/2023/micii_balcesti/poster_concurs_micii_balcesti.jpg\" width=\"949\" height=\"886\" style=\"display: block; margin-left: auto; margin-right: auto;\" class=\"responsive-img\"></p>\n<p align=\"center\" style=\"text-align: center; line-height: 150%;\">&nbsp;</p>\n<p align=\"center\" style=\"text-align: center; line-height: 200%;\">&nbsp;</p>\t\n\t\t</div>\n\t</div>\n<!--end news item -->\n<div id=\"bt-zt\"><a href=\"http://electrofans.net/\" target=\"_blank\" title=\"магазин музыкальных инструментов\">магазин музыкальных инструментов</a><br><a href=\"http://baby-market.org\" target=\"_blank\" title=\"купить детскую коляску\">купить детскую коляску</a></div>\n      <!-- end component -->\n            \t  <div class=\"clearm\"></div>\n    </div>\n    <!-- end mid block insidem class -->",
