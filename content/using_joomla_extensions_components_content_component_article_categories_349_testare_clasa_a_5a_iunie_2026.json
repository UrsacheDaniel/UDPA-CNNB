  "contentHtml": "\n<style>\n  .admissions-container {\n    font-family: 'Outfit', 'Inter', sans-serif;\n    color: #1f2937;\n    line-height: 1.6;\n    margin: 0 auto;\n    padding: 10px 0;\n  }\n  \n  /* Hero Section */\n  .admissions-hero {\n    background: linear-gradient(135deg, rgba(10, 37, 64, 0.95) 0%, rgba(11, 64, 122, 0.9) 100%);\n    color: white;\n    border-radius: 20px;\n    padding: 35px 30px;\n    margin-bottom: 30px;\n    position: relative;\n    overflow: hidden;\n    box-shadow: 0 10px 25px rgba(10, 37, 64, 0.15);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  \n  .admissions-hero::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    right: -20%;\n    width: 300px;\n    height: 300px;\n    background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);\n    border-radius: 50%;\n  }\n\n  .admissions-hero-title {\n    font-size: 2rem;\n    font-weight: 800;\n    color: #ffffff;\n    margin-bottom: 10px;\n    line-height: 1.3;\n  }\n\n  .admissions-hero-tag {\n    display: inline-block;\n    background: #d4af37;\n    color: #0a2540;\n    font-size: 0.8rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    padding: 4px 12px;\n    border-radius: 30px;\n    margin-bottom: 15px;\n    letter-spacing: 0.5px;\n  }\n\n  /* Info Key-Values Grid */\n  .info-bar-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n    gap: 16px;\n    margin-bottom: 30px;\n  }\n\n  .info-bar-card {\n    background: rgba(255, 255, 255, 0.8);\n    backdrop-filter: blur(8px);\n    -webkit-backdrop-filter: blur(8px);\n    border: 1px solid rgba(255, 255, 255, 0.6);\n    border-radius: 16px;\n    padding: 16px 20px;\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);\n    transition: all 0.3s ease;\n  }\n\n  .info-bar-card:hover {\n    transform: translateY(-2px);\n    border-color: rgba(11, 64, 122, 0.3);\n    box-shadow: 0 8px